<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Chromium's V8 JITs JavaScript; the renderer crashes under hardened
	     runtime without these two. Required for every Electron app. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<!-- Lets the app load native modules / dylibs not signed by our Team ID
	     (electron native addons, and the spawned ao daemon's dlopen path). -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<!-- Electron honors DYLD_* in dev/helper launches. -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
</dict>
</plist>
