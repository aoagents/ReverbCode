{
  "name": "agent-orchestrator",
  "private": true,
  "scripts": {
    "lint": "npm run lint:backend && npm run lint:web",
    "lint:backend": "cd backend && go test ./... && go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2 run --path-mode=abs",
    "lint:web": "pnpm -C frontend run lint",
    "format": "pnpm -C frontend run format",
    "frontend:typecheck": "pnpm -C frontend run typecheck",
    "web:dev": "pnpm -C frontend --filter @aoagents/ao-web dev",
    "web:build": "pnpm -C frontend --filter @aoagents/ao-web build",
    "web:test": "pnpm -C frontend --filter @aoagents/ao-web test",
    "build:frontend": "pnpm -C frontend --filter @aoagents/ao-web build && node scripts/copy-webui.mjs",
    "sqlc": "cd backend && go run github.com/sqlc-dev/sqlc/cmd/sqlc@v1.31.1 generate",
    "api:spec": "cd backend && go generate ./internal/httpd/apispec/...",
    "api:ts": "openapi-typescript backend/internal/httpd/apispec/openapi.yaml -o frontend/src/api/schema.ts",
    "api": "npm run api:spec && npm run api:ts"
  },
  "devDependencies": {
    "openapi-typescript": "7.4.4"
  }
}
